#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""boxboard — 人可观测入口。三件事,全程绕系统代理(ProxyHandler({})),
所以本机开着 Clash/Surge 也不会 502:
  1. 抓观察平面 /dashboard 的 HTML(单一渲染源=dashboard.go),写本地文件
     ~/.box-obs/dashboard.html,再 `open file://` —— 浏览器读本地文件,不经代理。
  2. 终端打印 ASCII 现状(人直接在终端看)。
  3. 落一份 markdown 快照进 obs-fleet box(留痕,人也能用任意 viewer 翻历史)。
Env: BOX_ENDPOINT(默认观察平面 :7788)."""
import sys, os, json, time, urllib.request, webbrowser, subprocess
EP = os.environ.get("BOX_ENDPOINT", "http://100.83.33.126:7788").rstrip("/")
TOK = os.environ.get("BOX_TOKEN", "")
OUT = os.path.expanduser("~/.box-obs/dashboard.html")
_op = urllib.request.build_opener(urllib.request.ProxyHandler({}))  # 绕代理,免 502

def _get(path):
    req = urllib.request.Request(EP + path)
    if TOK: req.add_header("Authorization", "Bearer " + TOK)
    with _op.open(req, timeout=20) as r:
        return r.read().decode(), r.getcode()

def mcp(m, pa, sid=None, notify=False):
    body = {"jsonrpc":"2.0","method":m,"params":pa}
    if not notify: body["id"]=1
    h = {"Content-Type":"application/json","Accept":"application/json, text/event-stream"}
    if TOK: h["Authorization"]="Bearer "+TOK
    if sid: h["Mcp-Session-Id"]=sid
    req = urllib.request.Request(EP+"/mcp", data=json.dumps(body).encode(), headers=h, method="POST")
    with _op.open(req, timeout=30) as r:
        ns=r.headers.get("Mcp-Session-Id"); raw=r.read().decode()
    if notify: return None, ns
    for ln in raw.splitlines():
        if ln.startswith("data: "): return json.loads(ln[6:]), ns
    return json.loads(raw), ns

def tool(sid, n, a):
    r,_ = mcp("tools/call", {"name":n,"arguments":a}, sid); res=r.get("result",{})
    if res.get("isError"): raise RuntimeError(res["content"][0]["text"])
    return json.loads(res["content"][0]["text"])

ELS = [("风","感知",["get","show","browse","trace","globes","summary","list","legend","neighbor","overview","observ","token_status"]),
       ("火","判断",["set_symbols","set_box_symbols","finish","abort","set_task","seal"]),
       ("土","成形",["store","create","replace","append"]),
       ("水","连接",["blob","upload","download","consume","sync","export","import","items_blob"]),
       ("空","治理",["gc","manual","lint"])]
def elem(op):
    f=op.lower()
    for kw in ("gc","manual","lint"):
        if kw in f: return "空"
    for s,_,kws in ELS:
        if any(k in f for k in kws): return s
    return "风"
def band(fr):
    return ("●●●","盛") if fr>=0.40 else ("●●○","温") if fr>=0.15 else ("●○○","微") if fr>0 else ("○○○","静")

def portrait():
    """返回 (ascii_str, markdown_str)。读 obs-fleet 各实例最新快照。"""
    _, sid = mcp("initialize", {"protocolVersion":"2024-11-05","capabilities":{},"clientInfo":{"name":"boxboard","version":"1.0"}})
    mcp("notifications/initialized", {}, sid, notify=True)
    b = tool(sid, "box_get_box_by_key", {"key":"obs-fleet"})
    items = tool(sid, "box_browse", {"box_id":b["id"],"limit":5000}).get("items",[])
    latest = {}
    for it in items:
        c = it.get("content")
        if not isinstance(c, dict): continue
        inst=c.get("instance","?"); ta=c.get("taken_at","")
        if inst not in latest or ta>latest[inst][0]: latest[inst]=(ta,c.get("snapshot",{}))
    A=["box 系统现状 · 觉痕仪表盘 (人面)",""]
    M=["# box 系统现状 · 觉痕仪表盘","","> 人机协同观察面 · 符号同源(觉痕/五元素)· 模糊非精确",""]
    if not latest:
        A.append("◯ obs-fleet 暂无快照"); M.append("◯ obs-fleet 暂无快照")
        return "\n".join(A), "\n".join(M), b["id"], sid
    for inst,(ta,snap) in sorted(latest.items()):
        cs=snap.get("counters",{}); byel={s:0 for s,_,_ in ELS}; tot=0; ops={}
        for k,v in cs.items():
            base=k.split("|",1)[0]
            if "." not in base: continue
            op,kind=base.rsplit(".",1); ops.setdefault(op,{"a":0,"e":0})
            if kind=="attempt": ops[op]["a"]+=v; byel[elem(op)]+=v; tot+=v
            elif kind=="error": ops[op]["e"]+=v
        ail=sorted(op for op,d in ops.items() if d["a"] and d["e"]/d["a"]>=0.30)
        hp=sum(1 for d in ops.values() if d["a"] and d["e"]==0)
        pa=sum(1 for d in ops.values() if d["a"] and 0<d["e"]/d["a"]<0.30)
        hot=[s for s,_,_ in ELS if band(byel[s]/tot if tot else 0)[1] in("盛","温")]
        A += [f"◐ {inst}   快照 {ta}", "  活法·五元素脉搏"]
        M += [f"## ◐ {inst}", f"_快照 {ta}_","","| 元素 | | 活力 |","|---|---|---|"]
        for s,nm,_ in ELS:
            g,w=band(byel[s]/tot if tot else 0)
            A.append(f"    {s} {nm}  {g} {w}")
            M.append(f"| {s} {nm} | {g} | {w} |")
        v="✗" if ail else "✓"
        A += [f"  活化态: {''.join(hot) or '—'} 主导",
              f"  健康·觉痕  ✓{hp} 健康  ~{pa} 亚  {v if ail else '✗'}{len(ail)} 病" + (f"  ({', '.join(ail)})" if ail else ""), ""]
        M += ["", f"**活化态**: {''.join(hot) or '—'} 主导  ",
              f"**健康**: ✓ {hp} 健康 · ~ {pa} 亚 · ✗ {len(ail)} 病" + (f" ({', '.join(ail)})" if ail else ""), ""]
    A.append("活力 ●●●盛 ●●○温 ●○○微 ○○○静 · 健康 ✓好 ~亚 ✗病")
    return "\n".join(A), "\n".join(M), b["id"], sid

def main():
    asc, md, fleet_id, sid = portrait()
    print(asc)                                            # 1) 终端 ASCII
    try:                                                  # 2) 本地 HTML(绕代理)
        html, code = _get("/dashboard")
        if code==200:
            os.makedirs(os.path.dirname(OUT), exist_ok=True)
            with open(OUT,"w") as f: f.write(html)
            print(f"\n[本地仪表盘] file://{OUT}  (浏览器开本地文件,绕代理免 502)")
            try: subprocess.run(["open", OUT], check=False)
            except Exception: webbrowser.open("file://"+OUT)
    except Exception as e:
        print(f"\n[本地仪表盘] 抓取 /dashboard 失败: {e}")
    try:                                                  # 3) 落 markdown 留痕
        ts = time.strftime("%Y%m%dT%H%M%SZ", time.gmtime())
        tool(sid, "box_store", {"box_id":fleet_id,
            "kind":"M", "source_type":"board",
            "storage_uri":f"row://board/render/{ts}",
            "idem_key":f"board-{ts}", "format":"markdown",
            "content": md,
            "labels":{"__op:sphere":"ops","board":"render","rendered_at":ts},
            "symbols":[{"kind":"kind","value":"M"},{"kind":"scope","value":"ops"},{"kind":"topic","value":"board-render"}]})
        print("[留痕] markdown 快照已落 obs-fleet box(人可用 viewer 翻历史)")
    except RuntimeError as e:
        print(f"[留痕] 跳过({e})")
main()
