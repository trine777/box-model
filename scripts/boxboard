#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""boxboard (v2 / R15) — 人面观察入口。读 obs-metrics 数字表(obs_v2_spec a6),
零五元素 / 零觉痕。全程绕系统代理(ProxyHandler({})),本机开 Clash/Surge 不 502。

三件事:
  1. 终端打印真实数字表(四类指标:容量 / task 完整度 / 性能 / 业务)。
  2. 抓观察平面 /dashboard 的 HTML(单一渲染源=dashboard.go),写本地文件
     ~/.box-obs/dashboard.html,再 `open file://` —— 浏览器读本地文件,不经代理。
  3. 落一份 markdown 数字表快照进 obs-fleet box 留痕(任意 viewer 可翻历史)。

Env: BOX_ENDPOINT(默认观察平面 :7788)、BOX_FLEET_EXPECT(期望实例)、BOX_TOKEN."""
import os, json, time, urllib.request, webbrowser, subprocess

EP = os.environ.get("BOX_ENDPOINT", "http://100.83.33.126:7788").rstrip("/")
TOK = os.environ.get("BOX_TOKEN", "")
EXPECT = [e.strip() for e in os.environ.get(
    "BOX_FLEET_EXPECT", "100.83.33.126:7777,100.83.33.126:7788").split(",") if e.strip()]
OUT = os.path.expanduser("~/.box-obs/dashboard.html")
_op = urllib.request.build_opener(urllib.request.ProxyHandler({}))  # 绕代理,免 502


def _get(path):
    req = urllib.request.Request(EP + path)
    if TOK:
        req.add_header("Authorization", "Bearer " + TOK)
    with _op.open(req, timeout=20) as r:
        return r.read().decode(), r.getcode()


def mcp(m, pa, sid=None, notify=False):
    body = {"jsonrpc": "2.0", "method": m, "params": pa}
    if not notify:
        body["id"] = 1
    h = {"Content-Type": "application/json", "Accept": "application/json, text/event-stream"}
    if TOK:
        h["Authorization"] = "Bearer " + TOK
    if sid:
        h["Mcp-Session-Id"] = sid
    req = urllib.request.Request(EP + "/mcp", data=json.dumps(body).encode(), headers=h, method="POST")
    with _op.open(req, timeout=30) as r:
        ns = r.headers.get("Mcp-Session-Id")
        raw = r.read().decode()
    if notify:
        return None, ns
    for ln in raw.splitlines():
        if ln.startswith("data: "):
            return json.loads(ln[6:]), ns
    return json.loads(raw), ns


def tool(sid, n, a):
    r, _ = mcp("tools/call", {"name": n, "arguments": a}, sid)
    res = r.get("result", {})
    if res.get("isError"):
        raise RuntimeError(res["content"][0]["text"])
    return json.loads(res["content"][0]["text"])


def gb(n):
    try:
        return n / (1024.0 ** 3)
    except Exception:
        return 0.0


def human_age(latest):
    if not latest:
        return "-"
    try:
        s = latest.split(".")[0].replace("Z", "")
        t = time.mktime(time.strptime(s, "%Y-%m-%dT%H:%M:%S"))
        d = time.time() - t
        if d < 3600:
            return f"{int(d/60)}m前"
        if d < 86400:
            return f"{int(d/3600)}h前"
        return f"{int(d/86400)}d前"
    except Exception:
        return latest[:10]


def fetch_latest(sid):
    """obs-metrics -> {instance: (taken_at, content)}。"""
    b = tool(sid, "box_get_box_by_key", {"key": "obs-metrics"})
    items = tool(sid, "box_browse", {"box_id": b["id"], "limit": 5000}).get("items", [])
    latest = {}
    for it in items:
        c = it.get("content")
        if not isinstance(c, dict):
            continue
        inst = c.get("instance", "?")
        ta = c.get("taken_at", "")
        if inst not in latest or ta > latest[inst][0]:
            latest[inst] = (ta, c)
    return latest


def aggregate_tasks(latest):
    """系统级 task 聚合(R15.1,口径同 dashboard.go / boxops)。"""
    total = stuck = 0
    by = {}
    durs = []
    for _, snap in latest.values():
        t = snap.get("tasks", {}) or {}
        total += t.get("total", 0)
        stuck += t.get("stuck", 0)
        for k, v in (t.get("by_status", {}) or {}).items():
            by[k] = by.get(k, 0) + v
        durs += (t.get("durations_ms", []) or [])
    cr = (by.get("✓", 0) / total) if total else 0.0
    davg = (sum(durs) / len(durs) / 1000.0) if durs else 0.0
    return total, by, cr, stuck, davg


def boards(latest):
    """返回 (terminal_text, markdown)。两者皆纯数字表,无符号。"""
    A = ["box 系统现状 · 数字表 (人面) · 观察平面 %s" % EP, ""]
    ts_now = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    M = ["# box 系统现状 · 工程数字表", "",
         "> obs_v2 真实指标快照 · 容量 / 性能 / 业务 · task 为系统级聚合 · 零符号抽象  ",
         "> 渲染于 %s · 端点 %s" % (ts_now, EP), ""]

    if not latest:
        A.append("(obs-metrics 暂无快照 — 先跑 boxsnap)")
        M.append("(obs-metrics 暂无快照 — 先跑 boxsnap)")
        return "\n".join(A), "\n".join(M)

    # 系统级 task 摘要(顶部,全舰队聚合)
    g_total, g_by, g_cr, g_stuck, g_davg = aggregate_tasks(latest)
    g_bystr = " ".join("%s%d" % (k, v) for k, v in sorted(g_by.items(), key=lambda kv: -kv[1])) or "-"
    g_sflag = "  !!stuck=%d" % g_stuck if g_stuck else ""
    A.append("[系统 task · 全舰队聚合] total %d  完整度 %.0f%%  by_status[%s]  avg %.0fs%s" % (
        g_total, g_cr * 100, g_bystr, g_davg, g_sflag))
    A.append("")
    M.append("## 系统 task(全舰队聚合)")
    M.append("**task**: total %d · 完整度 %.0f%% · by_status [%s] · avg %.0fs · stuck %d  " % (
        g_total, g_cr * 100, g_bystr, g_davg, g_stuck))
    M.append("")

    seen = set()
    for inst in sorted(latest, key=lambda i: (i not in EXPECT, i)):
        ta, snap = latest[inst]
        seen.add(inst)
        cap = snap.get("capacity", {})
        perf = snap.get("perf", {}).get("ops", [])
        biz = snap.get("business", {})
        down = snap.get("down")
        flag = " [DOWN]" if down else ""

        du, dt = cap.get("disk_used", 0), cap.get("disk_total", 0)
        dpct = (100.0 * du / dt) if dt else 0.0

        # --- terminal ---  (task 不再 per-instance,见顶部系统级摘要)
        A.append("== %s%s   快照 %s" % (inst, flag, ta))
        if down:
            A.append("   不可达: %s" % snap.get("error", "?"))
        A.append("  容量  disk %.1f%% (%.1f/%.1fGB) | box_home %.1fMB | blob %d/%.1fMB | "
                 "rss %sMB cpu %s%% up %.1fh" % (
                     dpct, gb(du), gb(dt), cap.get("box_home_bytes", 0) / 1048576.0,
                     cap.get("blob_count", 0), cap.get("blob_bytes", 0) / 1048576.0,
                     cap.get("proc_rss_mb", 0), cap.get("proc_cpu", 0),
                     cap.get("proc_uptime_s", 0) / 3600.0))
        A.append("  perf  %-22s %5s %5s %6s %5s %5s" % ("op", "calls", "err", "err%", "avg", "p95"))
        for o in sorted(perf, key=lambda o: (-o.get("err_pct", 0), -o.get("calls", 0)))[:6]:
            ep = o.get("err_pct", 0)
            avg, p95 = o.get("avg_ms"), o.get("p95_ms")
            A.append("        %-22s %5d %5d %5.0f%% %5s %5s%s" % (
                o.get("op", "?")[:22], o.get("calls", 0), o.get("errors", 0), ep,
                ("%.1f" % avg) if avg else "-", ("%.0f" % p95) if p95 else "-",
                " !" if ep >= 20 else ""))
        A.append("  biz   boxes %d items %d  top:" % (biz.get("box_count", 0), biz.get("item_total", 0)))
        for b in (biz.get("per_box", []) or [])[:6]:
            A.append("        %-22s items %5d uses %4d  %s" % (
                (b.get("key") or "?")[:22], b.get("items", 0), b.get("uses", 0),
                human_age(b.get("latest_stored_at"))))
        A.append("")

        # --- markdown ---
        M.append("## %s%s" % (inst, flag))
        M.append("_快照 %s_" % ta)
        if down:
            M.append("> 不可达: %s" % snap.get("error", "?"))
        M.append("")
        M.append("**容量**: disk %.1f%% (%.1f/%.1f GB) · box_home %.1f MB · blob %d / %.1f MB · "
                 "rss %s MB · cpu %s%% · up %.1f h  " % (
                     dpct, gb(du), gb(dt), cap.get("box_home_bytes", 0) / 1048576.0,
                     cap.get("blob_count", 0), cap.get("blob_bytes", 0) / 1048576.0,
                     cap.get("proc_rss_mb", 0), cap.get("proc_cpu", 0),
                     cap.get("proc_uptime_s", 0) / 3600.0))
        M += ["", "性能 (top):", "", "| op | calls | err | err% | avg ms | p95 ms |", "|---|---:|---:|---:|---:|---:|"]
        for o in sorted(perf, key=lambda o: (-o.get("err_pct", 0), -o.get("calls", 0)))[:8]:
            avg, p95 = o.get("avg_ms"), o.get("p95_ms")
            M.append("| %s | %d | %d | %.0f%% | %s | %s |" % (
                o.get("op", "?"), o.get("calls", 0), o.get("errors", 0), o.get("err_pct", 0),
                ("%.1f" % avg) if avg else "-", ("%.0f" % p95) if p95 else "-"))
        M += ["", "业务 per-box (top):", "", "| key | items | uses | updated |", "|---|---:|---:|---|"]
        for b in (biz.get("per_box", []) or [])[:8]:
            M.append("| %s | %d | %d | %s |" % (
                b.get("key") or "?", b.get("items", 0), b.get("uses", 0),
                human_age(b.get("latest_stored_at"))))
        M.append("")

    for inst in EXPECT:
        if inst not in seen:
            A.append("== %s [DOWN]  无任何快照(期望成员缺席)" % inst)
            M.append("## %s [DOWN]\n无任何快照(期望成员缺席)\n" % inst)
    return "\n".join(A), "\n".join(M)


def main():
    _, sid = mcp("initialize", {"protocolVersion": "2024-11-05", "capabilities": {},
                                "clientInfo": {"name": "boxboard", "version": "2.0"}})
    mcp("notifications/initialized", {}, sid, notify=True)
    try:
        latest = fetch_latest(sid)
    except RuntimeError as e:
        print("(读 obs-metrics 失败: %s — 此端点非 :7788? boxsnap 未跑?)" % e)
        return

    term, md = boards(latest)
    print(term)  # 1) 终端数字表

    try:  # 2) 本地 HTML(绕代理)
        html, code = _get("/dashboard")
        if code == 200:
            os.makedirs(os.path.dirname(OUT), exist_ok=True)
            with open(OUT, "w") as f:
                f.write(html)
            print("\n[本地仪表盘] file://%s  (浏览器开本地文件,绕代理免 502)" % OUT)
            try:
                subprocess.run(["open", OUT], check=False)
            except Exception:
                webbrowser.open("file://" + OUT)
        else:
            print("\n[本地仪表盘] /dashboard HTTP %s" % code)
    except Exception as e:
        print("\n[本地仪表盘] 抓取 /dashboard 失败: %s" % e)

    try:  # 3) 落 markdown 数字表留痕
        b = tool(sid, "box_get_box_by_key", {"key": "obs-fleet"})
        ts = time.strftime("%Y%m%dT%H%M%SZ", time.gmtime())
        tool(sid, "box_store", {
            "box_id": b["id"], "kind": "M", "source_type": "board",
            "storage_uri": f"row://board/render/{ts}",
            "idem_key": f"board-{ts}", "format": "markdown",
            "content": md,
            "labels": {"__op:sphere": "ops", "board": "render", "rendered_at": ts},
            "symbols": [{"kind": "kind", "value": "M"}, {"kind": "scope", "value": "ops"},
                        {"kind": "topic", "value": "board-render"}]})
        print("[留痕] markdown 数字表快照已落 obs-fleet box(可用任意 viewer 翻历史)")
    except RuntimeError as e:
        print("[留痕] 跳过(%s)" % e)


main()
