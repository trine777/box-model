#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""boxlife — 系统「活化」画像。box+agent = living system;agent 持续上报
是它的代谢。把每类上报操作归到 fengyin 五元素心智(风感知/火判断/土成形/
水连接/空抽象),用相对活力(模糊)刻画系统当下「在用哪种心智活着」。
SoR: fengyin/010-mind-five-elements (风火土水空)."""
import sys, json, os, urllib.request
EP = os.environ.get("BOX_ENDPOINT", "http://100.83.33.126:7777").rstrip("/")
TOK = os.environ.get("BOX_TOKEN", "")
_op = urllib.request.build_opener(urllib.request.ProxyHandler({}))
# 五元素 ← operation 关键词(忠实 fengyin SoR 职能定义)
ELEMENTS = [
    ("风", "感知·理解", ["get", "show", "browse", "trace", "globes", "summary", "list", "legend", "neighbor", "overview", "observ", "token_status"]),
    ("火", "判断·裁决", ["set_symbols", "set_box_symbols", "finish", "abort", "set_task", "seal"]),
    ("土", "成形·入库", ["store", "create", "replace", "append"]),
    ("水", "连接·流动", ["blob", "upload", "download", "consume", "sync", "export", "import", "items_blob"]),
    ("空", "抽象·治理", ["gc", "manual", "lint", "globes_all"]),
]
def classify(op):
    name = op.split(".")[-1] if "." in op else op
    full = op.lower()
    for el, _, kws in ELEMENTS:
        for kw in kws:
            if kw in full: return el
    return "风"  # default: a bare read
def bar(frac):
    # fuzzy 4-band activity glyph (模糊数学,非精确)
    if frac >= 0.40: return "●●●", "盛"
    if frac >= 0.15: return "●●○", "温"
    if frac > 0:     return "●○○", "微"
    return "○○○", "静"
def main():
    _, sid = _mcp_init()
    r, _ = _mcp("tools/call", {"name": "box_observability", "arguments": {}}, sid)
    snap = json.loads(r["result"]["content"][0]["text"])
    by_el = {el: 0 for el, _, _ in ELEMENTS}
    total = 0
    for k, v in snap.get("counters", {}).items():
        base = k.split("|", 1)[0]
        if not base.endswith(".attempt"): continue
        op = base[:-len(".attempt")]
        by_el[classify(op)] += v; total += v
    if total == 0:
        print("○ 系统静默 — 本进程尚无 agent 上报(重启清零;历史见 metrics box)"); return
    print("box 活化画像 · 五元素脉搏(agent 上报驱动的生命体征)")
    print("SoR: fengyin 风火土水空心智 · 模糊非精确,看活法不看数")
    print("─" * 46)
    bands = {}
    for el, name, _ in ELEMENTS:
        frac = by_el[el] / total
        glyph, word = bar(frac); bands[el] = word
        print(f"  {el} {name:<8} {glyph}  {word}")
    print("─" * 46)
    # 活化态:哪些元素盛/温 → 系统在认知循环(风→火→土→水→空)的哪个相位
    hot = [el for el, _, _ in ELEMENTS if bands[el] in ("盛", "温")]
    quiet = [el for el, _, _ in ELEMENTS if bands[el] == "静"]
    phase = "".join(hot) if hot else "—"
    print(f"活化态: {phase} 主导" + (f";{''.join(quiet)} 静" if quiet else ""))
    # 一句人话解读循环相位
    interp = {
        frozenset(["风"]): "纯感知 — 在盘点,未行动",
        frozenset(["风","土"]): "感知+积累 — 读着写着,未裁决/未流动",
        frozenset(["风","火"]): "感知+判断 — 在评估打觉痕",
        frozenset(["土"]): "纯入库 — 在结晶沉淀",
        frozenset(["水"]): "流动期 — 在同步/对外传输",
    }
    key = frozenset(hot)
    if key in interp: print(f"读解: {interp[key]}")
def _mcp(method, params, sid=None, notify=False):
    body = {"jsonrpc":"2.0","method":method,"params":params}
    if not notify: body["id"]=1
    h={"Content-Type":"application/json","Accept":"application/json, text/event-stream"}
    if TOK: h["Authorization"]="Bearer "+TOK
    if sid: h["Mcp-Session-Id"]=sid
    req=urllib.request.Request(EP+"/mcp",data=json.dumps(body).encode(),headers=h,method="POST")
    with _op.open(req,timeout=30) as r:
        ns=r.headers.get("Mcp-Session-Id"); raw=r.read().decode()
    if notify: return None,ns
    for ln in raw.splitlines():
        if ln.startswith("data: "): return json.loads(ln[6:]),ns
    return json.loads(raw),ns
def _mcp_init():
    _,sid=_mcp("initialize",{"protocolVersion":"2024-11-05","capabilities":{},"clientInfo":{"name":"boxlife","version":"1.0"}})
    _mcp("notifications/initialized",{},sid,notify=True); return None,sid
main()
