#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""boxlint — naming-standard guard (R12/R13). Every box must declare its
sphere as a SymScope SYMBOL (not just the legacy __op:sphere label). Reports
islands, label-only (un-migrated), out-of-vocab, bad key, missing owner."""
import sys, json, os, re, urllib.request
EP = os.environ.get("BOX_ENDPOINT", "http://100.83.33.126:7777").rstrip("/")
TOK = os.environ.get("BOX_TOKEN", "")
_op = urllib.request.build_opener(urllib.request.ProxyHandler({}))
SPHERES = {"dev", "km", "content", "media", "lab", "ops", "tmp"}
KEYRE = re.compile(r"^[a-z0-9-]+$")
def _mcp(method, params, sid=None, notify=False):
    body = {"jsonrpc": "2.0", "method": method, "params": params}
    if not notify: body["id"] = 1
    h = {"Content-Type": "application/json", "Accept": "application/json, text/event-stream"}
    if TOK: h["Authorization"] = "Bearer " + TOK
    if sid: h["Mcp-Session-Id"] = sid
    req = urllib.request.Request(EP + "/mcp", data=json.dumps(body).encode(), headers=h, method="POST")
    with _op.open(req, timeout=30) as r:
        ns = r.headers.get("Mcp-Session-Id"); raw = r.read().decode()
    if notify: return None, ns
    for ln in raw.splitlines():
        if ln.startswith("data: "): return json.loads(ln[6:]), ns
    return json.loads(raw), ns
def _tool(sid, n, a):
    r, _ = _mcp("tools/call", {"name": n, "arguments": a}, sid); res = r.get("result", {})
    if res.get("isError"): raise RuntimeError(res["content"][0]["text"])
    return json.loads(res["content"][0]["text"])
def main():
    _, sid = _mcp("initialize", {"protocolVersion": "2024-11-05", "capabilities": {}, "clientInfo": {"name": "boxlint", "version": "2.0"}})
    _mcp("notifications/initialized", {}, sid, notify=True)
    g = _tool(sid, "box_globes", {"max_boxes_per_sphere": 10000})
    keys = []
    for sph in g.get("globes", []): keys += [b["key"] for b in sph.get("boxes", [])]
    if g.get("unassigned"): keys += [b["key"] for b in g["unassigned"].get("boxes", [])]
    viol = 0
    print(f"{'box':<22} {'verdict'}")
    print("-" * 56)
    for key in sorted(set(keys)):
        b = _tool(sid, "box_get_box_by_key", {"key": key})
        labels = b.get("labels") or {}
        scope_sym = next((s["value"] for s in (b.get("symbols") or []) if s.get("kind") == "scope"), "")
        label_sphere = labels.get("__op:sphere", "")
        issues = []
        if scope_sym:
            if scope_sym not in SPHERES: issues.append(f"scope {scope_sym!r} not in vocab")
        elif label_sphere:
            issues.append(f"label-only sphere {label_sphere!r} — migrate to scope symbol")
        else:
            issues.append("ISLAND(no scope symbol)")
        if not KEYRE.match(key): issues.append("key not [a-z0-9-]")
        if not b.get("owner_id"): issues.append("no owner_id")
        if issues:
            viol += 1; print(f"{key:<22} ⚠ " + "; ".join(issues))
        else:
            print(f"{key:<22} ✓ scope:{scope_sym}")
    print(f"\n{viol} violation(s).")
    sys.exit(1 if viol else 0)
main()
